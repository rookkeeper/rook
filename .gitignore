# Secrets / local config
.env
.env.*
!.env.example

# Local scratch space
IGNORED/
haxxor_docs/

# Local app state
.var/

# Dependencies
node_modules/

# Build output
dist/
build/
.vite/
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local payload captures
provider/payload.jsonl
.pi/provider-payload.jsonl

# Python caches
__pycache__/
*.py[cod]

# OS/editor noise
.DS_Store

# Skill-local generated artifacts
my-agent/skills/youtube-transcript/node_modules/
my-agent/skills/youtube-transcript/.env

# Swift package build artifacts (matches clients/RookKit/.build/ and any nested .build)
.build/
.swiftpm/
DerivedData/

# Xcode user state (the .xcodeproj bundles themselves are tracked)
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
